# 1) Loyiha papkasida nusxa:  copy .env.local.example .env.local  (Windows: copy)
# 2) Supabase Dashboard > Settings > API:
#    - Project URL  -> NEXT_PUBLIC_SUPABASE_URL
#    - anon public  -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# 3) Authentication > Users: foydalanuvchi qo‘shing
#    Email:    admin1@demo.uz
#    Parol:    admin1234
#    (yoki forma: login="admin1" — @demo.uz avtomatik qo‘shiladi)
# 4) SQL: avval schema.sql, keyin seed.sql (Table Editor yoki SQL Editor)
#
# Mahalliy sinovda Supabase yo‘q ham bo‘lsa kirish (`nsms` / `Nsms2026!`):
# NEXT_PUBLIC_ENABLE_OFFLINE_DEMO=true
# `next start` uchun shu qator build vaqtida o‘qiladi — o‘zgartirsangiz qayta `npm run build`.
# Vercelda offline demo kod yo‘li ishlamaydi (VERCEL=1). Productionda faqat haqiqiy Supabase URL/kalit.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Production deploy: faqat yuqoridagi kalitlar (anon public). Service role kalitini hech qachon NEXT_PUBLIC yoki frontga qo‘shmang.
